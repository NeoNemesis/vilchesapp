# ============================================
# VilchesApp Backend — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/vilchesapp"

# JWT Secret (generate a strong random string)
JWT_SECRET="change-me-to-a-strong-random-secret-key"

# Server
PORT=3001
NODE_ENV=development

# Email (SMTP) — Optional, enable in Settings
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM_NAME="Your Company"
SMTP_FROM_EMAIL=your-email@example.com

# Email Monitoring (IMAP) — Optional
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=your-email@example.com
IMAP_PASS=your-email-password
IMAP_TLS=true
DISABLE_EMAIL_MONITORING=true

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# Base URLs
BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
COMPANY_NAME="Your Company Name"
COMPANY_EMAIL=info@yourcompany.com

# Webhook API Key (generate a random hex string)
WEBHOOK_API_KEY=change-me-to-a-random-hex-string

# Google Analytics (Optional)
# GOOGLE_APPLICATION_CREDENTIALS=./analytics-credentials.json
# GA4_PROPERTY_ID=your-ga4-property-id

# SMS via 46elks (Optional — Swedish SMS provider)
# ELKS_API_USERNAME=your-46elks-username
# ELKS_API_PASSWORD=your-46elks-password
# ELKS_FROM_NUMBER=YourCompany

# Telegram Notifications (Optional)
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_CHAT_ID=your-telegram-chat-id

# n8n Automation (Optional)
# N8N_INTERNAL_URL=http://localhost:5678
# N8N_EXTERNAL_URL=http://your-server:5678
# N8N_WEBHOOK_URL=http://your-server:5678/webhook
# N8N_API_KEY=your-n8n-api-key
