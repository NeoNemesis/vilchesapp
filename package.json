{
  "name": "vilchesapp",
  "version": "1.0.0",
  "description": "Professional project management system for contractors and service companies",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "db:generate": "cd backend && npm run prisma:generate",
    "db:migrate": "cd backend && npm run prisma:migrate",
    "db:studio": "cd backend && npm run prisma:studio",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "format": "npm run format:backend && npm run format:frontend",
    "format:backend": "cd backend && npm run format",
    "format:frontend": "cd frontend && npm run format"
  },
  "keywords": [
    "property-management",
    "construction",
    "contractor-management",
    "project-management",
    "sweden",
    "entreprenör",
    "bygg",
    "fastighet"
  ],
  "author": "Victor Vilches (NeoNemesis)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NeoNemesis/vilchesapp.git"
  },
  "bugs": {
    "url": "https://github.com/NeoNemesis/vilchesapp/issues"
  },
  "homepage": "https://github.com/NeoNemesis/vilchesapp#readme",
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "concurrently": "^8.2.2"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
