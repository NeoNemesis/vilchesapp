# ============================================
# VilchesApp — .gitignore
# ============================================

# Dependencies
node_modules/
.pnp
.pnp.js
jspm_packages/
bower_components/

# Build output
backend/dist/
frontend/dist/
build/
.next/
out/
*.tsbuildinfo

# Environment & secrets — NEVER commit these
.env
.env.local
.env.production
.env.development
.env.*.local
backend/.env
frontend/.env
frontend/.env.production
*credentials*.json
service-account*.json
*.pem
*.key
secrets/

# Uploaded files (user data — unique per installation)
backend/uploads/
uploads/
public/uploads/

# Customer data (personal information)
offerter/

# Development/debug scripts with hardcoded data
backend/*.js
!backend/jest.config.js

# Root-level debug scripts
check-emails.js

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# IDE & Editors
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Coverage & Testing
coverage/
.nyc_output/
*.lcov

# Docker volumes
postgres_data/
db_data/

# Cache
.npm
.eslintcache
.stylelintcache
.cache
.parcel-cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Misc
*.tgz
*.tar.gz
tmp/
temp/
.grunt
.node_repl_history
lib-cov/
